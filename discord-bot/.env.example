# =============================================================================
# Discord 봇 환경 변수 (index.mjs 기준 전체)
# 이 파일을 복사: cp .env.example .env  후 값만 채우세요. .env 는 Git 에 넣지 마세요.
# =============================================================================

# -----------------------------------------------------------------------------
# [필수] 없으면 봇이 시작 시 종료합니다.
# -----------------------------------------------------------------------------

# Developer Portal → 해당 앱 → Bot → Reset Token
DISCORD_BOT_TOKEN=여기에_봇_토큰

# 기본 알림 채널 (개발자 모드 → 텍스트 채널 우클릭 → ID 복사, 숫자만)
DISCORD_CHANNEL_ID=채널_ID_숫자만

# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# service_role (secret). 웹·GitHub 에 절대 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# -----------------------------------------------------------------------------
# [권장] 레이드·웹 DB 연동 — 전체 자동 알림에 필요
# -----------------------------------------------------------------------------

# 슬롯·당일 알림 시각 등 로컬 타임존 (한국 서버면 유지)
REMIND_TZ=Asia/Seoul

# 출발 **당일** 아침 알림 시각 (0~23). 기본 6 → 06:00 (REMIND_TZ 기준)
REMIND_DAY_HOUR=6

# 알림 대상 raid_type. 비우면 rudra + bagot + lostark 전부.
# 한 종류만: lostark / 여러 개: rudra,bagot
REMINDER_RAID_TYPE=

# -----------------------------------------------------------------------------
# [권장] 채널 분기 — 레이드 종류별로 다른 채널 (비우면 위 DISCORD_CHANNEL_ID 사용)
# -----------------------------------------------------------------------------

# DISCORD_CHANNEL_ID_RUDRA=
# DISCORD_CHANNEL_ID_BAGOT=
# DISCORD_CHANNEL_ID_LOSTARK=

# -----------------------------------------------------------------------------
# [선택] `/remind` 슬래시 + 채팅 알람 — 사용자 알람 전체
# -----------------------------------------------------------------------------
# · 슬래시 `/remind` 만: 0 (또는 미설정) — Portal Intent 불필요
# · 채팅 「알람 N분 뒤」까지: 1 — Portal → Bot → Privileged Gateway Intents → MESSAGE CONTENT ON 필수
#   (안 켰는데 1이면 `Used disallowed intents` 로 봇이 죽을 수 있음)
REMIND_CHAT_ENABLED=0

# 채팅 트리거 접두어. 비우면 봇 멘션+시간 문장만 인식
REMIND_MSG_PREFIX=알람

# 예약 상태 파일 (재시작 복구). VM 에서 절대 경로 권장 가능
REMIND_ALARM_PATH=./pending-alarms.json

# 알람 최소·최대 지연(ms). 기본 5초 ~ 7일
REMIND_MIN_MS=5000
REMIND_MAX_MS=604800000

# 채널 전송 실패 시 재시도(기본 12회·15초 간격). 권한 오류 시 로그에 Discord code 표시
# REMIND_SEND_MAX_RETRY=12
# REMIND_SEND_RETRY_MS=15000

# 사용자당 동시 예약 개수 상한
REMIND_MAX_PER_USER=10

# -----------------------------------------------------------------------------
# [선택] 레이드 틱 — 부하·저사양 VM 튜닝
# -----------------------------------------------------------------------------

# Supabase 폴링 주기(ms). 기본 60000. Oracle 소형 VM 등은 90000~120000 권장
POLL_INTERVAL_MS=60000

# sent-reminders.json 오래된 키 삭제(일)
STATE_PRUNE_RAID_DAYS=14

# 레이드 알림 전송 기록 파일 경로
SENT_STATE_PATH=./sent-reminders.json

# -----------------------------------------------------------------------------
# [선택] 터미널 테스트 — npm run test-notify
# -----------------------------------------------------------------------------

TEST_NOTIFY_RAID_TYPE=rudra
# TEST_NOTIFY_DISCORD_ID=

# =============================================================================
# 전체 기능 요약 (체크)
# · 레이드 당일·30분 전 알림: 필수 4개 + REMIND_TZ + (선택) 채널 분기·REMINDER_RAID_TYPE
# · 파티 `/party_recruit`: Supabase 마이그레이션에 party 테이블 적용됨
# · 사용자 알람 `/remind`: 위 설정으로 충분
# · 채팅 알람: REMIND_CHAT_ENABLED=1 + Bot 탭 MESSAGE CONTENT Intent + (선택) REMIND_MSG_PREFIX
# =============================================================================
