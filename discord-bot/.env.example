# Discord 봇 (Developer Portal → Bot → Reset Token / Copy)
DISCORD_BOT_TOKEN=여기에_봇_토큰

# 알림을 보낼 텍스트 채널 ID (Discord에서 개발자 모드 켠 뒤 채널 우클릭 → ID 복사)
# → **기본값**: 이 채널로 rudra / bagot / lostark 알림이 갑니다.
DISCORD_CHANNEL_ID=채널_ID_숫자만

# (선택) 레이드 타입별로 **다른 채널**에 내리려면 (있으면 DISCORD_CHANNEL_ID 대신 사용)
# DISCORD_CHANNEL_ID_RUDRA=루드라용_채널_ID
# DISCORD_CHANNEL_ID_BAGOT=바고트용_채널_ID
# DISCORD_CHANNEL_ID_LOSTARK=로아용_채널_ID

# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# service_role 키 (secret). 절대 웹·GitHub Pages에 넣지 마세요. 이 봇이 돌아가는 서버에만.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# 슬롯·리마인드 시각을 해석할 타임존 (한국이면 아래 그대로)
REMIND_TZ=Asia/Seoul

# (선택) 출발 **당일** 아침 알림 시각(0~23). 기본 6 → 06:00 로컬
# REMIND_DAY_HOUR=6

# (선택) 알릴 raid_type. 비우면 rudra·bagot·lostark 전부.
# 한 개: lostark / 여러 개(쉼표): rudra,bagot
# REMINDER_RAID_TYPE=rudra,bagot
# REMINDER_RAID_TYPE=lostark

# (선택) 중복 방지용 상태 파일 경로
# SENT_STATE_PATH=./sent-reminders.json

# (선택) 폴링 주기(ms). 기본 60000(1분). Oracle 무료 1GB VM 등이면 90000~120000 권장(부하·OOM 완화)
# POLL_INTERVAL_MS=90000

# (선택) sent-reminders.json 오래된 키 자동 삭제(일). 기본 레이드 14일·슈상보 10일 — 파일·메모리 비대 방지
# STATE_PRUNE_RAID_DAYS=14
# STATE_PRUNE_SUGO_DAYS=10

# (선택) npm run test-notify — 어떤 raid_type 기준으로 채널을 고를지
# TEST_NOTIFY_RAID_TYPE=rudra
# (선택) 테스트 시 본인 멘션까지 확인하려면 Discord 사용자 ID(숫자)
# TEST_NOTIFY_DISCORD_ID=
